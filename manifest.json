{
  "manifest_version": 3,
  "name": "Chrome Native Messaging Automation Bridge",
  "version": "1.0.1",
  "description": "Trusted-local Chrome automation bridge over native messaging.",
  "permissions": [
    "nativeMessaging",
    "tabs",
    "scripting",
    "activeTab",
    "cookies",
    "debugger",
    "alarms",
    "storage",
    "downloads",
    "contentSettings"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
