{
  "mcpServers": {
    "chrome-bridge": {
      "command": "uvx",
      "args": [
        "--from",
        "/ABSOLUTE/PATH/TO/chrome-native-bridge/mcp",
        "chrome-bridge-mcp"
      ],
      "env": {
        "BRIDGE_REPO_ROOT": "/ABSOLUTE/PATH/TO/chrome-native-bridge",
        "BRIDGE_PORT": "9223"
      }
    }
  }
}
